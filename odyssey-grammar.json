    "B_narrative_weight": {
      "name": "Gramática por Peso Narrativo",
      "description": "Entities filtered by narrative weight. Protagonists get full L2, minor characters get L1 props, genealogical-only entities get no 3D representation. Drastically reduces instance count.",
      "world_json_complexity": "medium",
      "artistic_control": "high",
      "automation_level": "medium",
      "fidelity_to_text": "high (important things stand out)",
      "performance": "high",
      "cell_count_estimate": 20,
      "draw_calls_estimate": 35,
      "total_kb_estimate": 1800,
      "filter_rules": {
        "excluded_from_3d": ["Eupites", "Pisenor", "Polibo", "Icario", "Anquíalo", "Ops"],
        "reason": "These entities have 0 attributes and exist only as genealogical references (padre_de of someone). They contribute nothing to visual storytelling."
      }
    },
    "C_relational": {
      "name": "Gramática Relacional (Edge-Driven)",
      "description": "Relationships between entities drive geometry. Ally→same banner color+proximity, Enemy→barrier+minimum distance, Parent→adjacent+road. The graph structure determines the grid layout.",
      "world_json_complexity": "high (includes constraints)",
      "artistic_control": "medium",
      "automation_level": "medium",
      "fidelity_to_text": "high (relationships visible)",
      "performance": "medium",
      "cell_count_estimate": 35,
      "draw_calls_estimate": 65,
      "total_kb_estimate": 3500,
      "signature_mechanic": "enemy_factions_get_barriers_between_territories"
    },
    "D_attribute_driven": {
      "name": "Gramática Procedural Atributo→Asset",
      "description": "YAML attributes directly select registry assets via a scoring system. The most generative approach — world.json can be auto-generated from ontology alone. Least predictable but most scalable.",
