  "relation_rules": {
    "aliado_de": {
      "3d_effect": "same_banner_color + adjacent_cells (distance ≤ 1)",
      "validation": "if A aliado_de B, then A.banner.color === B.banner.color"
    },
    "enemigo_de": {
      "3d_effect": "barrier_or_wall_between + minimum_distance_2",
      "validation": "if A enemigo_de B, then hexDistance(A.cell, B.cell) >= 2, and a barrier asset is placed on the edge between territories",
      "assets": ["barrier", "barrier_half", "barrier_column", "wall_half"]
    },
    "padre_de": {
      "3d_effect": "adjacent_cell (distance = 1) + road_connecting",
      "validation": "if A padre_de B, then B is placed distance 1 from A, connected by hex_road_A"
    },
    "hijo_de": {
      "3d_effect": "inverse of padre_de — same rule applies",
      "validation": "mirror of padre_de"
    },
    "pertenece_a": {
      "3d_effect": "sets banner_color from faction + groups cells in same region",
      "validation": "all members of X faction share X.banner.color"
    },
    "ubicado_en": {
      "3d_effect": "RESOLVES COORDINATES — entity is placed at the Lugar's (q,r)",
      "validation": "CRITICAL: if no ubicado_en, entity is 'in transit' and not rendered in initial grid"
    }
  },

