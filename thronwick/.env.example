# Cloudflare R2 origin used by the browser asset loader.
# Connect the production bucket to this custom domain before enabling it in Netlify.
VITE_ASSET_BASE_URL=https://assets.frokie.com/

# Temporary rollout safety net. Set to true for preview validation, then remove
# or set to false once R2 CORS and production delivery are verified.
VITE_ASSET_LOCAL_FALLBACK=true
